<Window x:Class="SpectrumVisualizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spectrum Visualizer"
        Width="1000"
        Height="700"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2*" />
            <RowDefinition Height="3*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <ToolBar Grid.Row="0">
            <Button Content="Start"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding CanStart}"
                    Padding="12,4"
                    Margin="4" />
            <Button Content="Stop"
                    Command="{Binding StopCommand}"
                    IsEnabled="{Binding CanStop}"
                    Padding="12,4"
                    Margin="4" />
        </ToolBar>

        <!-- Spectrogram placeholder -->
        <Border Grid.Row="1"
                Background="#1E1E1E"
                BorderBrush="Gray"
                BorderThickness="1"
                Margin="4">
            <TextBlock Text="Spectrogram"
                       Foreground="White"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>

        <!-- Waterfall placeholder -->
        <Border Grid.Row="2"
                Background="#1E1E1E"
                BorderBrush="Gray"
                BorderThickness="1"
                Margin="4">
            <TextBlock Text="Waterfall"
                       Foreground="White"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
